APP_NAME=Netra
ENVIRONMENT=development
FRONTEND_ORIGINS=http://localhost:3000
# Optional for Vercel preview deployments:
FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app

POSTGRES_DB=netra
POSTGRES_USER=netra_user
POSTGRES_PASSWORD=netra_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional for Render/Railway/Supabase-style deployments:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

REDIS_HOST=localhost
REDIS_PORT=6379
# Optional for Render/Upstash-style deployments:
# REDIS_URL=redis://default:password@host:6379
